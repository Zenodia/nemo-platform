from typing import Annotated, Literal
from pathlib import Path

import typer

from nemo_platform_ext.cli.core.api import build_kwargs, merge_filter_dict
from nemo_platform_ext.cli.core.context import CLIContext
from nemo_platform_ext.cli.core.errors import handle_errors
from nemo_platform_ext.cli.core.help_formatter import create_typer_app


@app.command("{{ cli_command_name }}")
@handle_errors
def {{ function_name }}(
    ctx: typer.Context,
    {% for p in path_params %}{{ p.to_typer_argument() }}{% endfor %}
    {% for p in parameters %}{{ p.to_typer_option() }}{% endfor %}
    output_file: Annotated[Path, typer.Option("--output-file", "-o", help="Output file path")] = ...,
) -> None:
    """{{ help_text }}"""
    state: CLIContext = ctx.obj
    client = state.get_client()

    kwargs = build_kwargs({% for k in kwargs_entries %}{{ k.to_kwargs_line() }}{% endfor %})
    result = client.{{ sdk_accessor }}.{{ method_name }}(
        {% if path_params %}{{ path_params | map(attribute='var_name') | join(', ') }}, {% endif %}
        **kwargs
    )

    result.write_to_file(output_file)
    typer.echo(f"✓ Downloaded to {output_file!r}")
