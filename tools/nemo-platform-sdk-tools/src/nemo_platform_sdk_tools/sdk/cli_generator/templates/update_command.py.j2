import json
from typing import Annotated, Literal

import typer

from nemo_platform_ext.cli.core.code_generator import handle_code_generation
from nemo_platform_ext.cli.core.context import CLIContext
from nemo_platform_ext.cli.core.errors import handle_errors
from nemo_platform_ext.cli.core.formatters import format_output
from nemo_platform_ext.cli.core.help_formatter import collect_warnings
from nemo_platform_ext.cli.core.stdin_utils import read_data_input_with_flags, read_payload, validate_required_fields
from nemo_platform_ext.cli.core.types import EntityOutputFormatOption


@app.command("{{ cli_command_name }}")
@collect_warnings
@handle_errors
def {{ function_name }}(
    ctx: typer.Context,
    {% for p in path_params %}{{ p.to_typer_argument() }}
    {% endfor %}{% for p in parameters if p.is_positional %}{{ p.to_typer_argument() }}
    {% endfor %}{% for p in parameters if not p.is_positional %}{{ p.to_typer_option() }}
    {% endfor %}input_file: Annotated[str | None, typer.Option("--input-file", help="Path to JSON file (use '-' for stdin)", rich_help_panel="Input Options")] = None,
    input_data: Annotated[str | None, typer.Option("--input-data", help="Input data for the request (JSON or YAML)", rich_help_panel="Input Options")] = None,
    output_format: EntityOutputFormatOption = None,
) -> None:
    """{{ help_text }}
{% if required_fields %}

    [bold red]Required fields:[/] {{ required_fields|join(', ') }}
{% endif %}

    [green]Examples:[/]
    nemo {{ resource_path|map('to_kebab')|join(' ') }} {{ cli_command_name }} {% for p in path_params %}<{{ p.var_name }}> {% endfor %}{% for p in parameters if p.is_positional %}<{{ p.var_name }}> {% endfor %}--input-file config.json
    nemo {{ resource_path|map('to_kebab')|join(' ') }} {{ cli_command_name }} {% for p in path_params %}<{{ p.var_name }}> {% endfor %}{% for p in parameters if p.is_positional %}<{{ p.var_name }}> {% endfor %}--input-data '{% if required_fields_example %}{{"{"}}{{ required_fields_example }}{{"}"}}{% else %}{"field": "value"}{% endif %}'
    echo '{"json": "data"}' | nemo {{ resource_path|map('to_kebab')|join(' ') }} {{ cli_command_name }} {% for p in path_params %}<{{ p.var_name }}> {% endfor %}{% for p in parameters if p.is_positional %}<{{ p.var_name }}> {% endfor %}--input-file -
{% if parameters|rejectattr("is_positional")|list %}
    nemo {{ resource_path|map('to_kebab')|join(' ') }} {{ cli_command_name }} {% for p in path_params %}<{{ p.var_name }}> {% endfor %}{% for p in parameters if p.is_positional %}<{{ p.var_name }}> {% endfor %}--<option> "value"
{% endif %}
    """
    # Read base input (optional if all fields provided via flags)
    if input_file or input_data:
        input_payload = read_data_input_with_flags(input_file=input_file, input_data=input_data)
    else:
        input_payload = {}

    # Apply CLI flag overrides (flags take precedence)
{% for p in parameters %}
    {% if p.is_list_type %}
    if {{ p.var_name }}:  # Check for non-empty list
        input_payload["{{ p.var_name }}"] = {{ p.var_name }}
    {% elif p.needs_json_parse %}
    if {{ p.var_name }} is not None:
        input_payload["{{ p.var_name }}"] = read_payload("{{ p.var_name }}", {{ p.var_name }})
    {% else %}
    if {{ p.var_name }} is not None:
        input_payload["{{ p.var_name }}"] = {{ p.var_name }}
    {% endif %}
{% endfor %}
{% if required_fields %}
    # Validate required fields are present after merging
    validate_required_fields(
        input_payload,
        {{ required_fields }},
        "{{ resource_path|map('to_kebab')|join(' ') }} {{ cli_command_name }}",
        { {% for p in parameters %}{% if p.is_required %}"{{ p.var_name }}": {% if p.help %}"{{ p.help }}"{% else %}None{% endif %}, {% endif %}{% endfor %}}
    )
{% endif %}

{% if path_params %}
    all_kwargs = { {% for p in path_params %}"{{ p.var_name }}": {{ p.var_name }}, {% endfor %}**input_payload}
{% else %}
    all_kwargs = input_payload
{% endif %}

    state: CLIContext = ctx.obj
    output_format = state.get_output_format(output_format)

    if handle_code_generation([{{ resource_path_quoted }}], "{{ method_name }}", all_kwargs, output_format, state):
        return

    client = state.get_client()
    result = client.{{ sdk_accessor }}.{{ method_name }}(**all_kwargs)

    format_output(
        result,
        is_list=False,
        output_format=output_format,
        no_truncate=state.get_no_truncate(),
        timestamp_format=state.get_timestamp_format(),
    )
