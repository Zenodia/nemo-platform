{
    "model": {
        "name": "meta/llama-3.2-3b-instruct",
        "url": "https://integrate.api.nvidia.com/v1"
    },
    "dataset": {
        "rows": [
            {"input": "hi.", "output": "hello world"},
            {"input": "Are you hungry?", "output": "no"},
            {"input": "What is coffee?", "output": "a hot drink made from the roasted and ground seeds (coffee beans) of a tropical shrub."}
        ]
    },
    "prompt_template": {
        "messages": [{"role": "user", "content": "{{input}}"}]
    },
    "params": {
        "limit_samples": 1,
        "inference": {
            "max_tokens": 2048
        }
    },
    "metric": {
        "type": "llm-judge",
        "name": "my-metric-length",
        "namespace": "why-not-default",
        "model": {
            "name": "meta/llama-3.3-70b-instruct",
            "url": "https://integrate.api.nvidia.com/v1"
        },
        "prompt_template": {
            "messages": [
                {"role": "system", "content": "You are an expert judge evaluating the length of AI responses."},
                {"role": "user", "content": "Question: {{input}}\nAnswer: {{output_text}}"}
            ]
        },
        "scores": [
            {
                "name": "length",
                "rubric": [
                    {"label": "short", "value": 0},
                    {"label": "medium", "value": 1},
                    {"label": "long", "value": 2}
                ],
                "parser": {
                    "type": "json",
                    "json_path": "length"
                }
            }
        ],
        "structured_output": {
            "schema": {
                "type": "object",
                "properties": {
                    "length": {
                        "type": "string",
                        "enum": ["short", "medium", "long"]
                    }
                },
                "required": ["length"],
                "additionalProperties": false
            }
        }
    }
}
