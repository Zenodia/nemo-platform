{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "nmp"
  ],
  "sandbox": {
    "excludedCommands": [
      "docker *",
      "docker-compose *",
      "make bootstrap",
      "make bootstrap-studio"
    ],
    "filesystem": {
      "allowWrite": [
        "$HOME/.config/nmp",
        "$HOME/.local/share/nemo"
      ]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/web/.claude/hooks/post-edit.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/web/.claude/hooks/nvm-on-cd.sh"
          }
        ]
      }
    ]
  }
}
