{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "packages/studio/playwright.config.ts",
    "packages/studio/e2e-tests/**",
    "packages/studio/screenshots/**"
  ],
  "workspaces": {
    "packages/studio": {
      "playwright": false,
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/common": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/scripts": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
