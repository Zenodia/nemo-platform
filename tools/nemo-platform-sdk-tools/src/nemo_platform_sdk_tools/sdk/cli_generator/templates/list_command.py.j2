from typing import Annotated, Literal

import typer

from nemo_platform_ext.cli.core.api import build_kwargs, merge_filter_dict
from nemo_platform_ext.cli.core.code_generator import handle_code_generation
from nemo_platform_ext.cli.core.context import CLIContext
from nemo_platform_ext.cli.core.errors import handle_errors
from nemo_platform_ext.cli.core.formatters import Column, check_output_columns_with_format, format_output
from nemo_platform_ext.cli.core.help_formatter import collect_warnings
from nemo_platform_ext.cli.core.pagination import PaginationType, fetch_all_pages, warn_if_more_pages
from nemo_platform_ext.cli.core.types import ListOutputFormatOption, NoTruncateOption, OutputColumnsOption


@app.command("{{ cli_command_name }}")
@collect_warnings
@handle_errors
def {{ function_name }}(
    ctx: typer.Context,
    {% for p in path_params %}{{ p.to_typer_argument() }}{% endfor %}
    {% for p in parameters %}{{ p.to_typer_option() }}{% endfor %}
    output_format: ListOutputFormatOption = None,
    no_truncate: NoTruncateOption = None,
    columns: OutputColumnsOption = None,
    {% if pagination_type != "NOT_PAGINATED" %}all_pages: Annotated[bool, typer.Option("--all-pages", help="Fetch all pages")] = False,{% endif %}
) -> None:
    """{{ help_text }}"""
    state: CLIContext = ctx.obj
    output_format = state.get_output_format(output_format)

    check_output_columns_with_format(columns, output_format)

    default_columns = [{% for col in columns %} Column({{ col.field | repr }}, {{ col.header | repr }}), {% endfor %}]
    if columns is None or str(columns).strip() == "default":
        columns = default_columns

    kwargs = build_kwargs({% for k in kwargs_entries %}{{ k.to_kwargs_line() }}{% endfor %})

    if handle_code_generation([{{ resource_path_quoted }}], "{{ method_name }}", kwargs, output_format, state):
        return

    client = state.get_client()
    path_args = ({% if path_params %}{{ path_params | map(attribute='var_name') | join(', ') }},{% endif %})
    {% if pagination_type != "NOT_PAGINATED" %}
    pagination_type = PaginationType.{{ pagination_type }}
    if all_pages:
        items = fetch_all_pages(
            client.{{ sdk_accessor }}.{{ method_name }},
            path_args=path_args,
            body_args=kwargs,
            pagination_type=pagination_type,
        )
    else:
        items = client.{{ sdk_accessor }}.{{ method_name }}(*path_args, **kwargs)
    {% else %}
    items = client.{{ sdk_accessor }}.{{ method_name }}(*path_args, **kwargs)
    {% endif %}

    format_output(
        items,
        is_list=True,
        output_format=output_format,
        output_columns=columns,
        no_truncate=state.get_no_truncate(no_truncate),
        timestamp_format=state.get_timestamp_format(),
    )
    {% if pagination_type != "NOT_PAGINATED" %}
    if not all_pages:
        warn_if_more_pages(items, pagination_type)
    {% endif %}
